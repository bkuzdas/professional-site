---
import Layout from '../../layouts/Layout.astro';
const accent = '#5a1a00';
---
<Layout title="Head of IT / Executive Resume — Brian Kuzdas" page="resumes">

<section class="page-hero" style={`--hero-accent: ${accent};`}>
  <div class="container">
    <div class="resume-nav-bar">
      <a href="/resumes" class="back-link">← All Resumes</a>
      <div class="resume-switcher">
        <a href="/resume/engineer" class="rs-btn">⚙️ Engineer</a>
        <a href="/resume/manager" class="rs-btn">🧭 Manager</a>
        <a href="/resume/executive" class="rs-btn active">🏛️ Executive</a>
      </div>
    </div>
    <p class="section-label">Head of IT / C-Level Executive</p>
    <h1 class="page-hero-title">Brian Kuzdas</h1>
    <p class="page-hero-sub">
      Technology Executive · Strategic IT Leader · Digital Transformation &amp; Compliance Expert
    </p>
    <p class="page-hero-sub" style="margin-top:0.5rem; font-size:0.9rem;">
      📍 Madison, WI &nbsp;·&nbsp; 📧 contact@technicalriskarchitect.com &nbsp;·&nbsp; 📞 (608) 576-0655 &nbsp;·&nbsp;
      <a href="https://www.linkedin.com/in/brian-kuzdas-a176b945/" target="_blank" style="color:rgba(255,255,255,.8)">LinkedIn ↗</a>
    </p>
  </div>
</section>

<section class="section">
  <div class="container resume-body">

    <div class="resume-section">
      <h2 class="rs-heading">Executive Summary</h2>
      <p class="rs-summary">
        Technology executive and IT strategist with 25+ years of progressive leadership experience
        driving digital transformation, infrastructure modernization, and technology governance across
        heavily regulated industries. Demonstrated success building IT departments from the ground up,
        leading enterprise-scale transformations, and aligning technology investment with business
        strategy, risk appetite, and regulatory requirements. Combines deep technical credibility
        with executive communication skills and business ownership experience. Track record of
        delivering results without overspending — managing full OPEX and CAPEX accountability across
        biopharmaceutical, financial services, and enterprise environments.
      </p>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Executive Leadership Competencies</h2>
      <div class="exec-competencies">
        <div class="ec-item">
          <div class="ec-icon">🏗️</div>
          <div class="ec-title">IT Organization Building</div>
          <p>Built IT departments from zero — hiring, process design, culture, and operational maturity</p>
        </div>
        <div class="ec-item">
          <div class="ec-icon">💼</div>
          <div class="ec-title">Technology Strategy &amp; Roadmapping</div>
          <p>Multi-year technology investment planning aligned to business objectives, risk profile, and regulatory requirements</p>
        </div>
        <div class="ec-item">
          <div class="ec-icon">💰</div>
          <div class="ec-title">Financial Accountability</div>
          <p>Full OPEX and CAPEX budget ownership; consistent on-budget delivery of complex programs</p>
        </div>
        <div class="ec-item">
          <div class="ec-icon">📋</div>
          <div class="ec-title">Regulatory Leadership</div>
          <p>Led FDA inspections, cGMP CSV programs, and regulatory compliance strategy for manufacturing IT environments</p>
        </div>
        <div class="ec-item">
          <div class="ec-icon">🤝</div>
          <div class="ec-title">Executive Communication</div>
          <p>Effective at board-level communication, regulatory presentations, and cross-functional alignment</p>
        </div>
        <div class="ec-item">
          <div class="ec-icon">🔐</div>
          <div class="ec-title">Risk &amp; Security Governance</div>
          <p>Enterprise security strategy, Zero Trust architecture, and IT risk management in regulated environments</p>
        </div>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Career Progression</h2>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">Bankers Bank</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">Dec 2025 – Present</span>
        </div>
        <div class="exp-title">Senior Network Operations &amp; Security Specialist</div>
        <ul class="exp-bullets">
          <li>Setting strategic direction for on-premise AI adoption while managing regulatory alignment in a Federal Reserve member bank</li>
          <li>Leading enterprise security modernization — Zero Trust implementation, UEM strategy, and identity governance overhaul</li>
          <li>Advising senior leadership on technology investment priorities and security risk posture</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">FUJIFILM Cellular Dynamics, Inc.</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">May 2022 – Dec 2025</span>
        </div>
        <div class="exp-title">Manager, Technology Operations &amp; IT (de facto Head of IT)</div>
        <ul class="exp-bullets">
          <li>Functioned as Head of IT for global biopharmaceutical company manufacturing FDA-regulated iPSC cell therapy products</li>
          <li>Built the IT organization from the ground up — architecture, operations, compliance, team, and culture</li>
          <li>Owned and delivered OPEX and CAPEX technology budget with full financial accountability; zero overruns</li>
          <li>Set and executed multi-year IT strategy encompassing infrastructure, cloud transformation, and security hardening</li>
          <li>Led Computer System Validation (CSV) program — all IT systems validated to FDA 21 CFR Part 11 and cGMP requirements</li>
          <li>Maintained <strong>99.99% uptime</strong> across all manufacturing-critical systems; zero production impact from IT failures</li>
          <li>Served as IT executive liaison to FDA inspection teams; achieved zero IT-related audit findings across all inspections</li>
          <li>Directed HL7 FHIR R4 integration platform initiative — <strong>30% improvement</strong> in laboratory data retrieval</li>
          <li>Negotiated and managed technology vendor relationships, contracts, and service agreements</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">FUJIFILM Holdings America Corporation</span> <span class="exp-loc">— Valhalla, NY</span></div>
          <span class="exp-date">Aug 2017 – May 2022</span>
        </div>
        <div class="exp-title">IT System Administrator II — Enterprise Infrastructure</div>
        <ul class="exp-bullets">
          <li>Led strategic migration of <strong>60,000+ users</strong> from Google Workspace to Microsoft 365 — enterprise-wide transformation program</li>
          <li>Managed data center infrastructure strategy, capacity planning, and disaster recovery framework</li>
          <li>Contributed to enterprise IT governance and standardization initiatives across global business units</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">Madison Computer Works, Inc.</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">Mar 2016 – Aug 2017</span>
        </div>
        <div class="exp-title">Senior Network Infrastructure Specialist / vCIO</div>
        <ul class="exp-bullets">
          <li>Served as virtual CIO for SMB clients — technology strategy, investment planning, and transformation advisory</li>
          <li>Delivered infrastructure projects across multiple client verticals simultaneously</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">TBC Consulting LLC</span> <span class="exp-loc">— Mount Horeb, WI</span></div>
          <span class="exp-date">Apr 2012 – Mar 2016</span>
        </div>
        <div class="exp-title">CEO &amp; Founder — Managed Service Provider</div>
        <ul class="exp-bullets">
          <li>Founded and scaled technology services business to 25+ client organizations; full P&amp;L responsibility</li>
          <li>Set business strategy, managed investor/client relationships, directed all operations and service delivery</li>
          <li>Served as Chief Technology Officer and virtual CIO for client organizations across multiple industries</li>
        </ul>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Strategic &amp; Technical Proficiencies</h2>
      <div class="skills-cols">
        <div class="skill-col">
          <div class="skill-group-title">Leadership &amp; Strategy</div>
          <div class="skill-tags">
            <span class="tag">Technology Strategy</span><span class="tag">Digital Transformation</span>
            <span class="tag">IT Organization Design</span><span class="tag">Board-Level Communication</span>
            <span class="tag">Vendor Strategy</span><span class="tag">IT Governance</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Regulatory &amp; Compliance</div>
          <div class="skill-tags">
            <span class="tag">FDA 21 CFR Part 11</span><span class="tag">cGMP Computer System Validation</span>
            <span class="tag">IT Risk Management</span><span class="tag">Security Governance</span><span class="tag">ITIL 4</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Technology Domains</div>
          <div class="skill-tags">
            <span class="tag">Hybrid Cloud (Azure / AWS)</span><span class="tag">Enterprise Security</span>
            <span class="tag">Zero Trust Architecture</span><span class="tag">Data Center</span>
            <span class="tag">AI Infrastructure</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Business Acumen</div>
          <div class="skill-tags">
            <span class="tag">OPEX / CAPEX Ownership</span><span class="tag">Contract Negotiation</span>
            <span class="tag">Entrepreneurship</span><span class="tag">P&amp;L Responsibility</span>
            <span class="tag">Stakeholder Management</span>
          </div>
        </div>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Certifications &amp; Credentials</h2>
      <div class="cert-list">
        <div class="cert-item"><span class="ci-name">AWS Certified Cloud Practitioner</span><span class="ci-date">2025–2028</span></div>
        <div class="cert-item"><span class="ci-name">Microsoft Azure Fundamentals (AZ-900)</span><span class="ci-date">2026</span></div>
        <div class="cert-item"><span class="ci-name">CISSP Domain 1: Security &amp; Risk Management</span><span class="ci-date">Active</span></div>
        <div class="cert-item"><span class="ci-name">ITIL 4: Foundations &amp; Framework</span><span class="ci-date">Active</span></div>
        <div class="cert-item"><span class="ci-name">Google Project Management Specialization</span><span class="ci-date">Active</span></div>
        <div class="cert-item"><span class="ci-name">Computer System Validation Boot Camp — ProPharma Validation Center</span><span class="ci-date">2023</span></div>
        <div class="cert-item"><span class="ci-name">Siemens PLC / TIA Portal (Industrial Automation)</span><span class="ci-date">Active</span></div>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Education</h2>
      <div class="cert-list">
        <div class="cert-item"><span class="ci-name">BA — Political Science &amp; History, University of Wisconsin – Platteville</span></div>
        <div class="cert-item"><span class="ci-name">Computer Systems Networking, Madison Area Technical College</span></div>
      </div>
    </div>

  </div>
</section>

<section class="cta-section">
  <div class="container cta-inner">
    <div>
      <h2 class="cta-title">Looking for a strategic IT executive?</h2>
      <p class="cta-sub">I'm open to discussions about VP, CTO, CIO, and Head of IT opportunities.</p>
    </div>
    <div class="cta-actions">
      <a href="mailto:contact@technicalriskarchitect.com" class="btn btn-gold">Contact Brian</a>
      <a href="/api/document?name=Brian_Kuzdas_Head_of_IT.pdf" download class="btn btn-outline-white">⬇ Download PDF</a>
      <a href="/api/document?name=Brian_Kuzdas_Head_of_IT.docx" download class="btn btn-outline-white">⬇ Download Word</a>
      <a href="https://www.linkedin.com/in/brian-kuzdas-a176b945/" target="_blank" class="btn btn-outline-white">LinkedIn ↗</a>
      <a href="/resume/manager" class="btn btn-outline-white">← Manager Resume</a>
    </div>
  </div>
</section>

</Layout>

<style>
.resume-nav-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--sp-2xl); flex-wrap: wrap; gap: var(--sp-md); }
.back-link { color: rgba(255,255,255,.7); font-size: 0.875rem; font-weight: 500; }
.back-link:hover { color: var(--white); }
.resume-switcher { display: flex; gap: 6px; }
.rs-btn { font-size: 0.8rem; font-weight: 600; padding: 5px 14px; border-radius: 20px; border: 1px solid rgba(255,255,255,.3); color: rgba(255,255,255,.7); background: transparent; transition: all var(--transition); }
.rs-btn:hover, .rs-btn.active { background: rgba(255,255,255,.15); color: var(--white); border-color: rgba(255,255,255,.6); }
.resume-body { max-width: 860px; margin-inline: auto; }
.resume-section { margin-bottom: var(--sp-3xl); padding-bottom: var(--sp-3xl); border-bottom: 1px solid var(--border-soft); }
.resume-section:last-child { border: none; }
.rs-heading { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #5a1a00; margin-bottom: var(--sp-lg); padding-bottom: var(--sp-sm); border-bottom: 2px solid #5a1a00; }
.rs-summary { font-size: 0.95rem; color: var(--sub); line-height: 1.8; max-width: 80ch; }
.exec-competencies { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--sp-lg); }
.ec-item { background: var(--light); border: 1px solid var(--border-soft); border-radius: var(--r-md); padding: var(--sp-lg); }
.ec-icon { font-size: 1.5rem; margin-bottom: var(--sp-sm); }
.ec-title { font-weight: 700; color: var(--navy); font-size: 0.9rem; margin-bottom: 6px; }
.ec-item p { font-size: 0.82rem; color: var(--sub); line-height: 1.6; }
.skills-cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--sp-lg); }
.skill-group-title { font-size: 0.78rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.exp-block { margin-bottom: var(--sp-2xl); }
.exp-header { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--sp-md); margin-bottom: 4px; }
.exp-company { font-weight: 800; color: var(--navy); font-size: 1rem; }
.exp-loc { font-size: 0.85rem; color: var(--muted); }
.exp-date { font-size: 0.82rem; color: var(--gold); font-weight: 600; flex-shrink: 0; }
.exp-title { font-size: 0.9rem; color: var(--sub); font-style: italic; font-weight: 600; margin-bottom: var(--sp-md); }
.exp-bullets { padding-left: 1.25rem; }
.exp-bullets li { font-size: 0.875rem; color: var(--muted); line-height: 1.65; margin-bottom: 0.4rem; }
.exp-bullets strong { color: var(--navy); }
.cert-list { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--border-soft); border-radius: var(--r-md); overflow: hidden; }
.cert-item { display: flex; justify-content: space-between; gap: var(--sp-md); padding: 10px var(--sp-lg); border-bottom: 1px solid var(--border-soft); font-size: 0.875rem; }
.cert-item:last-child { border-bottom: none; }
.cert-item:nth-child(even) { background: var(--light); }
.ci-name { color: var(--sub); }
.ci-date { color: var(--gold); font-weight: 600; flex-shrink: 0; }
.cta-section { background: linear-gradient(135deg, var(--navy-dark), var(--navy)); padding-block: var(--sp-3xl); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-2xl); }
.cta-title { font-size: 1.5rem; font-weight: 800; color: var(--white); margin-bottom: var(--sp-sm); }
.cta-sub { font-size: 0.9rem; color: rgba(255,255,255,.7); }
.cta-actions { display: flex; flex-wrap: wrap; gap: var(--sp-md); }
@media (max-width: 760px) { .exp-header { flex-direction: column; } .cta-inner { flex-direction: column; text-align: center; } .cta-actions { justify-content: center; } }
</style>
