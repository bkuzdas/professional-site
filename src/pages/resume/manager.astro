---
import Layout from '../../layouts/Layout.astro';
const accent = '#1a5c38';
---
<Layout title="IT Infrastructure Manager Resume — Brian Kuzdas" page="resumes">

<section class="page-hero" style={`--hero-accent: ${accent};`}>
  <div class="container">
    <div class="resume-nav-bar">
      <a href="/resumes" class="back-link">← All Resumes</a>
      <div class="resume-switcher">
        <a href="/resume/engineer" class="rs-btn">⚙️ Engineer</a>
        <a href="/resume/manager" class="rs-btn active">🧭 Manager</a>
        <a href="/resume/executive" class="rs-btn">🏛️ Executive</a>
      </div>
    </div>
    <p class="section-label">IT Infrastructure Manager</p>
    <h1 class="page-hero-title">Brian Kuzdas</h1>
    <p class="page-hero-sub">
      Technology Operations Manager · IT Infrastructure Leader · Team Builder &amp; Budget Owner
    </p>
    <p class="page-hero-sub" style="margin-top:0.5rem; font-size:0.9rem;">
      📍 Madison, WI &nbsp;·&nbsp; 📧 brian.kuzdas@gmail.com &nbsp;·&nbsp; 📞 (608) 576-0655 &nbsp;·&nbsp;
      <a href="https://www.linkedin.com/in/brian-kuzdas-a176b945/" target="_blank" style="color:rgba(255,255,255,.8)">LinkedIn ↗</a>
    </p>
  </div>
</section>

<section class="section">
  <div class="container resume-body">

    <div class="resume-section">
      <h2 class="rs-heading">Professional Summary</h2>
      <p class="rs-summary">
        Results-driven IT Infrastructure Manager with 25+ years of progressive experience leading teams,
        delivering complex infrastructure projects, and managing technology operations in highly regulated environments.
        Proven track record managing OPEX and CAPEX budgets, building IT departments from the ground up,
        and aligning technology strategy with business objectives. Deep expertise in cGMP-regulated biopharmaceutical
        manufacturing (FDA 21 CFR Part 11), financial services, hybrid cloud, and enterprise IT operations.
        Strong communicator at all organizational levels — from data center to boardroom.
      </p>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Leadership &amp; Management Capabilities</h2>
      <div class="skills-cols">
        <div class="skill-col">
          <div class="skill-group-title">Team &amp; People Management</div>
          <div class="skill-tags">
            <span class="tag">IT Team Leadership</span><span class="tag">Hiring &amp; Onboarding</span>
            <span class="tag">Performance Management</span><span class="tag">Mentoring</span>
            <span class="tag">Cross-functional Collaboration</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Project &amp; Program Delivery</div>
          <div class="skill-tags">
            <span class="tag">Project Management (Google PM)</span><span class="tag">Infrastructure Roadmapping</span>
            <span class="tag">Vendor Management</span><span class="tag">SLA / OLA Governance</span>
            <span class="tag">Change Management</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Financial Accountability</div>
          <div class="skill-tags">
            <span class="tag">OPEX Budget Ownership</span><span class="tag">CAPEX Planning</span>
            <span class="tag">Vendor Contract Negotiation</span><span class="tag">Cost Optimization</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Compliance &amp; Risk</div>
          <div class="skill-tags">
            <span class="tag">FDA 21 CFR Part 11</span><span class="tag">cGMP / Computer System Validation</span>
            <span class="tag">IT Risk Management</span><span class="tag">DR / BCP Planning</span>
            <span class="tag">ITIL 4</span>
          </div>
        </div>
        <div class="skill-col">
          <div class="skill-group-title">Technical Domains (Working Knowledge)</div>
          <div class="skill-tags">
            <span class="tag">Hybrid Cloud (Azure/AWS)</span><span class="tag">Network Architecture</span>
            <span class="tag">Zero Trust Security</span><span class="tag">VMware</span><span class="tag">Endpoint Management</span>
          </div>
        </div>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Professional Experience</h2>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">Bankers Bank</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">Dec 2025 – Present</span>
        </div>
        <div class="exp-title">Senior Network Operations &amp; Security Specialist</div>
        <ul class="exp-bullets">
          <li>Leading security modernization and network operations strategy in a federally regulated financial institution</li>
          <li>Driving Unified Endpoint Management (UEM) transition — planning, vendor selection, phased rollout</li>
          <li>Establishing Zero Trust security architecture to reduce attack surface and improve identity governance</li>
          <li>Collaborating with senior leadership to align IT security investments with regulatory requirements</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">FUJIFILM Cellular Dynamics, Inc.</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">May 2022 – Dec 2025</span>
        </div>
        <div class="exp-title">Manager, Technology Operations &amp; IT (promoted from Sr. Infrastructure Specialist, Oct 2022)</div>
        <ul class="exp-bullets">
          <li>Managed all IT operations — helpdesk, infrastructure, networking, storage, endpoint management — for an FDA-regulated cGMP manufacturing site</li>
          <li>Owned OPEX and CAPEX technology budgets; delivered all major projects on time and within budget</li>
          <li>Built and led the IT function from a startup phase to a mature, validated, audit-ready organization</li>
          <li>Maintained <strong>99.99% uptime</strong> across manufacturing-critical systems with zero unplanned downtime impacting production</li>
          <li>Led Computer System Validation (CSV) lifecycle for all IT systems under FDA 21 CFR Part 11 and cGMP requirements</li>
          <li>Managed vendor relationships, contract negotiations, and third-party IT service providers</li>
          <li>Served as primary IT liaison during FDA inspections; achieved zero IT-related audit findings</li>
          <li>Developed and executed multi-year IT infrastructure roadmap aligned with business growth objectives</li>
          <li>Hired, onboarded, and mentored IT staff; built high-performing, self-sufficient operations team</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">FUJIFILM Holdings America Corporation</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">Aug 2017 – May 2022</span>
        </div>
        <div class="exp-title">IT System Administrator II</div>
        <ul class="exp-bullets">
          <li>Led enterprise-wide migration of <strong>60,000+ users</strong> from Google Workspace to Microsoft 365 — largest platform migration in the organization's history</li>
          <li>Coordinated cross-functional project team including vendor partners, business unit stakeholders, and IT operations</li>
          <li>Managed multi-site enterprise data center: physical/virtual servers, SAN/NAS storage, and networking</li>
          <li>Designed and tested disaster recovery procedures; owned BCP documentation for IT systems</li>
          <li>Developed process documentation, runbooks, and knowledge base content to improve team consistency</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">Madison Computer Works, Inc.</span> <span class="exp-loc">— Madison, WI</span></div>
          <span class="exp-date">Mar 2016 – Aug 2017</span>
        </div>
        <div class="exp-title">Senior Network Infrastructure Specialist</div>
        <ul class="exp-bullets">
          <li>Delivered network design and implementation projects for commercial clients, managing scope, timeline, and quality</li>
          <li>Provided vCIO advisory services — technology roadmapping and budget planning for SMB clients</li>
          <li>Mentored junior technicians and developed internal documentation standards</li>
        </ul>
      </div>

      <div class="exp-block">
        <div class="exp-header">
          <div><span class="exp-company">TBC Consulting LLC</span> <span class="exp-loc">— Mount Horeb, WI</span></div>
          <span class="exp-date">Apr 2012 – Mar 2016</span>
        </div>
        <div class="exp-title">CEO / Founder — Managed Service Provider</div>
        <ul class="exp-bullets">
          <li>Founded and operated MSP from zero clients to 25+ active organizations in Greater Madison</li>
          <li>Managed all business operations: P&amp;L, staffing, vendor relationships, contracts, and client delivery</li>
          <li>Served as virtual CIO for client organizations across multiple industries</li>
          <li>Delivered managed networking, server management, backup/DR, helpdesk, and technology planning</li>
        </ul>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Certifications</h2>
      <div class="cert-list">
        <div class="cert-item"><span class="ci-name">AWS Certified Cloud Practitioner</span><span class="ci-date">Sep 2025 – Sep 2028</span></div>
        <div class="cert-item"><span class="ci-name">Microsoft Azure Fundamentals (AZ-900)</span><span class="ci-date">Feb 2026</span></div>
        <div class="cert-item"><span class="ci-name">Google Project Management Specialization</span><span class="ci-date">Active</span></div>
        <div class="cert-item"><span class="ci-name">ITIL 4: Foundations &amp; Framework</span><span class="ci-date">Active</span></div>
        <div class="cert-item"><span class="ci-name">CISSP Domain 1: Security &amp; Risk Management</span><span class="ci-date">Active</span></div>
        <div class="cert-item"><span class="ci-name">Computer System Validation Boot Camp — ProPharma</span><span class="ci-date">2023</span></div>
        <div class="cert-item"><span class="ci-name">Dell EMC Unity Implementation &amp; Management</span><span class="ci-date">2020</span></div>
      </div>
    </div>

    <div class="resume-section">
      <h2 class="rs-heading">Education</h2>
      <div class="cert-list">
        <div class="cert-item"><span class="ci-name">BA — Political Science &amp; History, University of Wisconsin – Platteville</span></div>
        <div class="cert-item"><span class="ci-name">Computer Systems Networking, Madison Area Technical College</span></div>
      </div>
    </div>

  </div>
</section>

<section class="cta-section">
  <div class="container cta-inner">
    <div>
      <h2 class="cta-title">Ready to discuss an opportunity?</h2>
      <p class="cta-sub">I'd love to connect and learn more about your team and goals.</p>
    </div>
    <div class="cta-actions">
      <a href="mailto:brian.kuzdas@gmail.com" class="btn btn-gold">Email Brian</a>
      <a href="/docs/Brian_Kuzdas_IT_Infrastructure_Manager.docx" download class="btn btn-outline-white">⬇ Download .docx</a>
      <a href="https://www.linkedin.com/in/brian-kuzdas-a176b945/" target="_blank" class="btn btn-outline-white">LinkedIn ↗</a>
      <a href="/resume/executive" class="btn btn-outline-white">Executive Resume →</a>
    </div>
  </div>
</section>

</Layout>

<style>
.resume-nav-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--sp-2xl); flex-wrap: wrap; gap: var(--sp-md); }
.back-link { color: rgba(255,255,255,.7); font-size: 0.875rem; font-weight: 500; }
.back-link:hover { color: var(--white); }
.resume-switcher { display: flex; gap: 6px; }
.rs-btn { font-size: 0.8rem; font-weight: 600; padding: 5px 14px; border-radius: 20px; border: 1px solid rgba(255,255,255,.3); color: rgba(255,255,255,.7); background: transparent; transition: all var(--transition); }
.rs-btn:hover, .rs-btn.active { background: rgba(255,255,255,.15); color: var(--white); border-color: rgba(255,255,255,.6); }
.resume-body { max-width: 860px; margin-inline: auto; }
.resume-section { margin-bottom: var(--sp-3xl); padding-bottom: var(--sp-3xl); border-bottom: 1px solid var(--border-soft); }
.resume-section:last-child { border: none; }
.rs-heading { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #1a5c38; margin-bottom: var(--sp-lg); padding-bottom: var(--sp-sm); border-bottom: 2px solid #1a5c38; }
.rs-summary { font-size: 0.95rem; color: var(--sub); line-height: 1.8; max-width: 80ch; }
.skills-cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--sp-lg); }
.skill-group-title { font-size: 0.78rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.exp-block { margin-bottom: var(--sp-2xl); }
.exp-header { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--sp-md); margin-bottom: 4px; }
.exp-company { font-weight: 800; color: var(--navy); font-size: 1rem; }
.exp-loc { font-size: 0.85rem; color: var(--muted); }
.exp-date { font-size: 0.82rem; color: var(--gold); font-weight: 600; flex-shrink: 0; }
.exp-title { font-size: 0.9rem; color: var(--sub); font-style: italic; font-weight: 600; margin-bottom: var(--sp-md); }
.exp-bullets { padding-left: 1.25rem; }
.exp-bullets li { font-size: 0.875rem; color: var(--muted); line-height: 1.65; margin-bottom: 0.4rem; }
.exp-bullets strong { color: var(--navy); }
.cert-list { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--border-soft); border-radius: var(--r-md); overflow: hidden; }
.cert-item { display: flex; justify-content: space-between; gap: var(--sp-md); padding: 10px var(--sp-lg); border-bottom: 1px solid var(--border-soft); font-size: 0.875rem; }
.cert-item:last-child { border-bottom: none; }
.cert-item:nth-child(even) { background: var(--light); }
.ci-name { color: var(--sub); }
.ci-date { color: var(--gold); font-weight: 600; flex-shrink: 0; }
.cta-section { background: linear-gradient(135deg, var(--navy-dark), var(--navy)); padding-block: var(--sp-3xl); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-2xl); }
.cta-title { font-size: 1.5rem; font-weight: 800; color: var(--white); margin-bottom: var(--sp-sm); }
.cta-sub { font-size: 0.9rem; color: rgba(255,255,255,.7); }
.cta-actions { display: flex; flex-wrap: wrap; gap: var(--sp-md); }
@media (max-width: 760px) { .exp-header { flex-direction: column; } .cta-inner { flex-direction: column; text-align: center; } .cta-actions { justify-content: center; } }
</style>
