---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Achievements — Brian Kuzdas" page="achievements">

<section class="page-hero">
  <div class="container">
    <p class="section-label">Impact &amp; Results</p>
    <h1 class="page-hero-title">Key Achievements</h1>
    <p class="page-hero-sub">
      Measurable outcomes, transformative projects, and career-defining wins
      across 25+ years of enterprise IT leadership.
    </p>
  </div>
</section>

<!-- ══ METRICS ══════════════════════════════════════════ -->
<section class="section--white">
  <div class="container">
    <div class="metrics-strip">
      <div class="metric-cell">
        <span class="metric-val">99.99%</span>
        <span class="metric-lbl">Infrastructure Uptime</span>
      </div>
      <div class="metric-cell">
        <span class="metric-val gold">60K+</span>
        <span class="metric-lbl">Users Migrated</span>
      </div>
      <div class="metric-cell">
        <span class="metric-val">30%</span>
        <span class="metric-lbl">Data Retrieval Improvement</span>
      </div>
      <div class="metric-cell">
        <span class="metric-val gold">25+</span>
        <span class="metric-lbl">MSP Clients Served</span>
      </div>
      <div class="metric-cell">
        <span class="metric-val">0</span>
        <span class="metric-lbl">FDA Audit Failures</span>
      </div>
      <div class="metric-cell">
        <span class="metric-val gold">$0</span>
        <span class="metric-lbl">Budget Overruns</span>
      </div>
    </div>
  </div>
</section>

<!-- ══ FLAGSHIP PROJECTS ═══════════════════════════════ -->
<section class="section">
  <div class="container">
    <p class="section-label">Major Projects</p>
    <h2 class="section-title">Flagship Achievements</h2>
    <div class="section-divider"></div>

    <div class="projects-grid">

      <div class="project-card project-card--featured">
        <div class="pc-header">
          <span class="pc-num">01</span>
          <span class="pc-tag">cGMP Infrastructure</span>
        </div>
        <h3 class="pc-title">Greenfield cGMP IT Infrastructure — FUJIFILM Cellular Dynamics</h3>
        <p class="pc-context">As Manager of Technology Operations &amp; IT at a global biopharmaceutical company manufacturing FDA-regulated iPSC cell therapy products, I built and validated the entire IT environment from the ground up.</p>
        <ul class="pc-bullets">
          <li>Designed and built all server, storage, networking, and cloud infrastructure supporting cGMP manufacturing operations</li>
          <li>Achieved and maintained <strong>99.99% uptime</strong> across all manufacturing-critical IT systems</li>
          <li>Validated all systems to <strong>FDA 21 CFR Part 11</strong> and cGMP Computer System Validation (CSV) requirements</li>
          <li>Passed multiple internal and external FDA inspections with zero IT-related audit findings</li>
          <li>Managed full OPEX and CAPEX technology budgets with zero overruns</li>
        </ul>
        <div class="pc-tags">
          <span class="tag tag--feat">FDA 21 CFR Part 11</span>
          <span class="tag tag--feat">cGMP CSV</span>
          <span class="tag tag--feat">99.99% Uptime</span>
          <span class="tag tag--feat">Greenfield Build</span>
        </div>
      </div>

      <div class="project-card project-card--featured">
        <div class="pc-header">
          <span class="pc-num">02</span>
          <span class="pc-tag">Cloud Migration</span>
        </div>
        <h3 class="pc-title">60,000-User Google Workspace → Microsoft 365 Migration</h3>
        <p class="pc-context">As IT System Administrator II at FUJIFILM Holdings America, I led the full-scale migration of the enterprise from Google Workspace to Microsoft 365 — one of the largest platform migrations in the organization's history.</p>
        <ul class="pc-bullets">
          <li>Migrated <strong>60,000+ users</strong> across a globally distributed enterprise with minimal disruption</li>
          <li>Coordinated data migration, identity provisioning, and application dependencies across multiple business units</li>
          <li>Developed migration runbooks, rollback procedures, and user training materials</li>
          <li>Collaborated with Microsoft and third-party vendors to ensure data integrity during cutover</li>
          <li>Project delivered on schedule with zero data loss and minimal end-user impact</li>
        </ul>
        <div class="pc-tags">
          <span class="tag tag--feat">60K+ Users</span>
          <span class="tag tag--feat">Microsoft 365</span>
          <span class="tag tag--feat">Zero Data Loss</span>
          <span class="tag tag--feat">Enterprise Scale</span>
        </div>
      </div>

      <div class="project-card">
        <div class="pc-header">
          <span class="pc-num">03</span>
          <span class="pc-tag">Network Engineering</span>
        </div>
        <h3 class="pc-title">HL7 FHIR R4 Data Ingestor Platform</h3>
        <p class="pc-context">Architected a laboratory data integration platform to connect scientific instrumentation to enterprise systems, enabling real-time data capture and retrieval for cGMP operations.</p>
        <ul class="pc-bullets">
          <li>Designed HL7 FHIR R4 ingestor architecture connecting lab instruments to downstream enterprise systems</li>
          <li>Delivered <strong>30% improvement</strong> in data retrieval speed versus legacy file-based workflows</li>
          <li>Implemented with full audit trail compliance under FDA 21 CFR Part 11</li>
          <li>Enabled scientific teams to query and report on instrument data in real time</li>
        </ul>
        <div class="pc-tags">
          <span class="tag">HL7 FHIR R4</span>
          <span class="tag">30% Improvement</span>
          <span class="tag">Lab Integration</span>
          <span class="tag">FDA Compliant</span>
        </div>
      </div>

      <div class="project-card">
        <div class="pc-header">
          <span class="pc-num">04</span>
          <span class="pc-tag">Security</span>
        </div>
        <h3 class="pc-title">WireGuard Zero Trust Remote Access Solution</h3>
        <p class="pc-context">Designed and deployed a modern Zero Trust network access solution to replace legacy VPN infrastructure, significantly improving security posture while maintaining accessibility for remote users.</p>
        <ul class="pc-bullets">
          <li>Implemented WireGuard-based Zero Trust tunnel solution for secure site-to-site and remote access</li>
          <li>Eliminated broad network access in favor of identity-aware, least-privilege connectivity</li>
          <li>Achieved significant reduction in attack surface versus legacy VPN approach</li>
          <li>Deployed without impacting cGMP manufacturing system availability</li>
        </ul>
        <div class="pc-tags">
          <span class="tag">WireGuard</span>
          <span class="tag">Zero Trust</span>
          <span class="tag">Remote Access</span>
          <span class="tag">Security Architecture</span>
        </div>
      </div>

      <div class="project-card">
        <div class="pc-header">
          <span class="pc-num">05</span>
          <span class="pc-tag">Automation</span>
        </div>
        <h3 class="pc-title">Windows Firewall Security Profiler</h3>
        <p class="pc-context">Developed an automated Windows firewall profiling and hardening tool using PowerShell to baseline and enforce security policies across the enterprise endpoint fleet.</p>
        <ul class="pc-bullets">
          <li>Built PowerShell-based tool to audit Windows Firewall policy compliance across managed endpoints</li>
          <li>Automated detection of policy drift and generated remediation reports for IT and security teams</li>
          <li>Significantly reduced manual audit effort and improved security policy enforcement consistency</li>
          <li>Integrated with existing monitoring and alerting infrastructure</li>
        </ul>
        <div class="pc-tags">
          <span class="tag">PowerShell</span>
          <span class="tag">Security Automation</span>
          <span class="tag">Endpoint Hardening</span>
          <span class="tag">Windows Firewall</span>
        </div>
      </div>

      <div class="project-card">
        <div class="pc-header">
          <span class="pc-num">06</span>
          <span class="pc-tag">Entrepreneurship</span>
        </div>
        <h3 class="pc-title">TBC Consulting LLC — Founded &amp; Operated MSP</h3>
        <p class="pc-context">Founded a Managed Service Provider from zero, built a book of 25+ clients, and operated successfully for 4 years before transitioning to enterprise IT leadership roles.</p>
        <ul class="pc-bullets">
          <li>Grew MSP to 25+ client organizations across multiple industries in Greater Madison, WI</li>
          <li>Managed all business functions: sales, service delivery, contracts, HR, and financial planning</li>
          <li>Delivered managed IT services including networking, server administration, helpdesk, and backup/DR</li>
          <li>Served as virtual CIO to business owners, providing strategic technology advisory services</li>
        </ul>
        <div class="pc-tags">
          <span class="tag">Entrepreneurship</span>
          <span class="tag">25+ Clients</span>
          <span class="tag">vCIO</span>
          <span class="tag">Business Owner</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ══ STRENGTHS ════════════════════════════════════════ -->
<section class="section section--alt">
  <div class="container">
    <p class="section-label">Professional Strengths</p>
    <h2 class="section-title">What Sets Me Apart</h2>
    <div class="section-divider"></div>
    <div class="strengths-grid">
      <div class="strength-card">
        <div class="str-icon">🏭</div>
        <div class="str-title">cGMP &amp; FDA Expertise</div>
        <p>One of a rare breed of IT professionals with direct, validated experience in FDA-regulated biopharmaceutical manufacturing environments — including 21 CFR Part 11 compliance and Computer System Validation (CSV).</p>
      </div>
      <div class="strength-card">
        <div class="str-icon">🛠️</div>
        <div class="str-title">Hands-On &amp; Strategic</div>
        <p>Equally comfortable in the data center configuring hardware and in the boardroom presenting technology strategy. I don't just manage IT — I do IT, and that technical depth makes me a stronger leader.</p>
      </div>
      <div class="strength-card">
        <div class="str-icon">💼</div>
        <div class="str-title">Business Ownership Mindset</div>
        <p>As a former MSP founder and OPEX/CAPEX budget owner, I understand that IT exists to serve the business. Every technology decision I make is grounded in business impact and financial accountability.</p>
      </div>
      <div class="strength-card">
        <div class="str-icon">📈</div>
        <div class="str-title">Track Record of Delivery</div>
        <p>Whether it's a 60,000-user migration, a greenfield cGMP infrastructure build, or a Zero Trust security overhaul — I deliver complex projects on time, on budget, and with measurable results.</p>
      </div>
      <div class="strength-card">
        <div class="str-icon">🔐</div>
        <div class="str-title">Security-First Architecture</div>
        <p>I design infrastructure with security baked in from the start — not bolted on after. Zero Trust, least privilege, network segmentation, and identity-centric access are core to my architectural approach.</p>
      </div>
      <div class="strength-card">
        <div class="str-icon">🤝</div>
        <div class="str-title">Cross-Functional Communication</div>
        <p>I've partnered effectively with scientists, manufacturing operators, executives, auditors, and regulators throughout my career — translating complex technical concepts into business language that drives alignment.</p>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container cta-inner">
    <div>
      <h2 class="cta-title">Ready to drive results at your organization?</h2>
      <p class="cta-sub">View my tailored resumes or reach out to discuss opportunities.</p>
    </div>
    <div class="cta-actions">
      <a href="/resumes" class="btn btn-gold">View Resumes</a>
      <a href="mailto:brian.kuzdas@gmail.com" class="btn btn-outline-white">Contact Me</a>
    </div>
  </div>
</section>

</Layout>

<style>
.metrics-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px,1fr)); }
.section--white { background: var(--white); padding-block: var(--sp-3xl); }

/* ── PROJECTS ── */
.projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: var(--sp-xl); }
.project-card {
  background: var(--white); border: 1px solid var(--border-soft);
  border-radius: var(--r-lg); padding: var(--sp-xl) var(--sp-2xl);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition), transform var(--transition);
}
.project-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.project-card--featured {
  grid-column: span 2;
  border-top: 3px solid var(--gold);
}
@media (max-width: 820px) { .project-card--featured { grid-column: span 1; } }
.pc-header {
  display: flex; align-items: center; gap: var(--sp-md);
  margin-bottom: var(--sp-md);
}
.pc-num {
  font-size: 2rem; font-weight: 900; color: var(--border);
  line-height: 1; letter-spacing: -0.05em;
}
.pc-tag {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gold); background: rgba(200,150,30,.1); padding: 3px 10px; border-radius: 20px;
}
.pc-title { font-size: 1.05rem; font-weight: 800; color: var(--navy); margin-bottom: var(--sp-md); line-height: 1.35; }
.pc-context { font-size: 0.9rem; color: var(--sub); line-height: 1.7; margin-bottom: var(--sp-md); }
.pc-bullets { padding-left: 1.25rem; margin-bottom: var(--sp-lg); }
.pc-bullets li { font-size: 0.875rem; color: var(--muted); line-height: 1.65; margin-bottom: 0.5rem; }
.pc-bullets strong { color: var(--navy); }
.pc-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.tag--feat { background: rgba(13,43,94,.08); color: var(--navy); border-color: rgba(13,43,94,.2); }

/* ── STRENGTHS ── */
.strengths-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
.strength-card {
  background: var(--white); border: 1px solid var(--border-soft);
  border-radius: var(--r-lg); padding: var(--sp-xl);
  box-shadow: var(--shadow-sm);
}
.str-icon { font-size: 2rem; margin-bottom: var(--sp-md); }
.str-title { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: var(--sp-sm); }
.strength-card p { font-size: 0.875rem; color: var(--sub); line-height: 1.7; }

/* ── CTA ── */
.cta-section { background: linear-gradient(135deg, var(--navy-dark), var(--navy)); padding-block: var(--sp-4xl); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-2xl); }
.cta-title { font-size: 1.8rem; font-weight: 800; color: var(--white); margin-bottom: var(--sp-sm); }
.cta-sub { font-size: 1rem; color: rgba(255,255,255,.7); max-width: 50ch; }
.cta-actions { display: flex; flex-wrap: wrap; gap: var(--sp-md); }

@media (max-width: 760px) {
  .cta-inner { flex-direction: column; text-align: center; }
  .cta-actions { justify-content: center; }
}
</style>
