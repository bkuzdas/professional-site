</Layout>

<style>
.metrics-strip { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px,1fr)); }
.section--white { background: var(--white); padding-block: var(--sp-3xl); }

/* ── PROJECTS ── */
.projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: var(--sp-xl); }
.project-card {
  background: var(--white); border: 1px solid var(--border-soft);
  border-radius: var(--r-lg); padding: var(--sp-xl) var(--sp-2xl);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition), transform var(--transition);
}
.project-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.project-card--featured {
  grid-column: span 2;
  border-top: 3px solid var(--gold);
}
@media (max-width: 820px) { .project-card--featured { grid-column: span 1; } }
.pc-header {
  display: flex; align-items: center; gap: var(--sp-md);
  margin-bottom: var(--sp-md);
}
.pc-num {
  font-size: 2rem; font-weight: 900; color: var(--border);
  line-height: 1; letter-spacing: -0.05em;
}
.pc-tag {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gold); background: rgba(200,150,30,.1); padding: 3px 10px; border-radius: 20px;
}
.pc-title { font-size: 1.05rem; font-weight: 800; color: var(--navy); margin-bottom: var(--sp-md); line-height: 1.35; }
.pc-context { font-size: 0.9rem; color: var(--sub); line-height: 1.7; margin-bottom: var(--sp-md); }
.pc-bullets { padding-left: 1.25rem; margin-bottom: var(--sp-lg); }
.pc-bullets li { font-size: 0.875rem; color: var(--muted); line-height: 1.65; margin-bottom: 0.5rem; }
.pc-bullets strong { color: var(--navy); }
.pc-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.tag--feat { background: rgba(13,43,94,.08); color: var(--navy); border-color: rgba(13,43,94,.2); }

/* ── STRENGTHS ── */
.strengths-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--sp-xl); }
.strength-card {
  background: var(--white); border: 1px solid var(--border-soft);
  border-radius: var(--r-lg); padding: var(--sp-xl);
  box-shadow: var(--shadow-sm);
}
.str-icon { font-size: 2rem; margin-bottom: var(--sp-md); }
.str-title { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: var(--sp-sm); }
.strength-card p { font-size: 0.875rem; color: var(--sub); line-height: 1.7; }

/* ── CERTIFICATIONS ── */
.certs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--sp-xl);
}
.cert-card {
  background: var(--white);
  border: 1px solid var(--border-soft);
  border-radius: var(--r-lg);
  padding: var(--sp-xl);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: var(--sp-md);
  transition: box-shadow var(--transition), transform var(--transition);
  border-top: 3px solid var(--border);
}
.cert-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.cert-card--aws   { border-top-color: #FF9900; }
.cert-card--azure { border-top-color: #0078D4; }
.cert-card--suny  { border-top-color: #e8b840; }
.cert-card--databricks { border-top-color: #FF3621; }
.cert-card--google     { border-top-color: #4285F4; }
.cert-card--okta       { border-top-color: #007DC1; }

.cert-badge {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cert-logo {
  width: 44px; height: 44px;
  border-radius: var(--r-md);
  display: flex; align-items: center; justify-content: center;
  font-weight: 900; font-size: 0.75rem; letter-spacing: 0.05em;
  color: #fff;
}
.cert-logo--aws  { background: #FF9900; color: #111; }
.cert-logo--ms   { background: #0078D4; }
.cert-logo--edu  { background: var(--cream); border: 1px solid var(--border); font-size: 1.3rem; }
.cert-logo--db   { background: #FF3621; }
.cert-logo--gcp  { background: #4285F4; font-size: 1.2rem; }
.cert-logo--okta { background: #007DC1; }

.cert-status {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; padding: 3px 10px;
  border-radius: 20px;
}
.cert-status--active {
  background: rgba(34,197,94,0.12);
  color: #16a34a;
}

.cert-body { flex: 1; }
.cert-title  { font-size: 1rem; font-weight: 800; color: var(--navy); margin-bottom: 4px; line-height: 1.35; }
.cert-issuer { font-size: 0.85rem; font-weight: 600; color: var(--sub); margin-bottom: 4px; }
.cert-date   { font-size: 0.8rem; color: var(--muted); margin-bottom: 2px; }
.cert-id     { font-size: 0.72rem; color: var(--muted); font-family: var(--font-mono); word-break: break-all; }

.cert-footer {
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: var(--sp-sm);
  padding-top: var(--sp-md);
  border-top: 1px solid var(--border-soft);
}
.cert-verify-btn {
  font-size: 0.78rem; font-weight: 700; color: var(--navy);
  text-decoration: none; letter-spacing: 0.03em;
  transition: color var(--transition);
}
.cert-verify-btn:hover { color: var(--gold); }

.cert-tag {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; padding: 2px 8px;
  border-radius: 20px; border: 1px solid;
}
.cert-tag--cloud    { background: rgba(0,120,212,.08); color: #0078D4; border-color: rgba(0,120,212,.2); }
.cert-tag--security { background: rgba(0,125,193,.08); color: #007DC1; border-color: rgba(0,125,193,.2); }
.cert-tag--data     { background: rgba(255,54,33,.08); color: #FF3621; border-color: rgba(255,54,33,.2); }
.cert-tag--tech     { background: var(--gold-muted); color: var(--gold); border-color: rgba(200,150,30,.3); }

/* ── CTA ── */
.cta-section { background: linear-gradient(135deg, var(--navy-dark), var(--navy)); padding-block: var(--sp-4xl); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-2xl); }
.cta-title { font-size: 1.8rem; font-weight: 800; color: var(--white); margin-bottom: var(--sp-sm); }
.cta-sub { font-size: 1rem; color: rgba(255,255,255,.7); max-width: 50ch; }
.cta-actions { display: flex; flex-wrap: wrap; gap: var(--sp-md); }

@media (max-width: 760px) {
  .cta-inner { flex-direction: column; text-align: center; }
  .cta-actions { justify-content: center; }
}
</style>
