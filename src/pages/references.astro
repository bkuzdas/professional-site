    email: "s.zwicky@gmail.com",
  },
  {
    name: "Coby Carlson",
    title: "Sr. Director, Commercial Applications",
    company: "FUJIFILM Cellular Dynamics",
    relationship: "Co-Worker / Internal Customer",
    phone: "608-217-4755",
    email: "coby.carlson@fujifilm.com",
  },
  {
    name: "Eugenia Jones",
    title: "VP External Dev & Partnerships",
    company: "FUJIFILM Cellular Dynamics",
    relationship: "Internal Customer",
    phone: "608-239-2580",
    email: "emcjones1@gmail.com",
  },
  {
    name: "Bernard Laymon",
    title: "Network Administrator III",
    company: "FUJIFILM HLUS",
    relationship: "Co-Worker",
    phone: "864-396-0890",
    email: "dominic.laymon@gmail.com",
  },
  {
    name: "Benjamin Seffrood",
    title: "Director, Finance & Accounting",
    company: "FCDI Admin",
    relationship: "Co-Worker",
    phone: "608-215-3067",
    email: "seffroodb@yahoo.com",
  },
  {
    name: "Rick Gadzinski",
    title: "Manager, Instrumentation & Validation",
    company: "FUJIFILM FCDI",
    relationship: "Co-Worker / Internal Customer",
    phone: "920-202-2299",
    email: "rick.gadzinski@fujifilm.com",
  },
  {
    name: "Andrew Wenborn",
    title: "VP of Quality",
    company: "FUJIFILM FCDI",
    relationship: "Co-Worker",
    phone: "608-770-3719",
    email: "andrew.wenborn@fujifilm.com",
  },
