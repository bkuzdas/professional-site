    title: "Network Administrator III",
    company: "FUJIFILM HLUS",
    relationship: "Co-Worker",
    phone: "864-396-0890",
    email: "dominic.laymon@gmail.com",
  },
  {
    name: "Benjamin Seffrood",
    title: "Director, Finance & Accounting",
    company: "FCDI Admin",
