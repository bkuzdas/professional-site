---
import DoorLayout from '../layouts/DoorLayout.astro';
---
<DoorLayout title="Brian Kuzdas — Professional Portfolio">

<div class="door">

  <!-- Background grid -->
  <div class="door-grid" aria-hidden="true"></div>

  <!-- Top bar -->
  <header class="door-header">
    <div class="door-logo">
      <span class="logo-mark">BK</span>
      <span class="logo-name">Brian Kuzdas</span>
    </div>
    <a href="https://brianboruma.com" class="door-ext" target="_blank" rel="noopener">
      brianboruma.com ↗
    </a>
  </header>

  <!-- Main content -->
  <main class="door-main">

    <div class="door-eyebrow">
      <span class="door-dot"></span>
      Senior IT Infrastructure · Network Security · Technology Leadership
    </div>

    <h1 class="door-headline">
      Welcome.<br/>
      <span class="door-headline-sub">This is a private portfolio.</span>
    </h1>

    <p class="door-desc">
      25+ years of enterprise IT experience across biopharmaceutical manufacturing,
      financial services, and technology leadership — available to qualified opportunities.
      Request access to view full career history, projects, and resumes.
    </p>

    <!-- Teaser stats -->
    <div class="door-stats">
      <div class="ds-item">
        <span class="ds-val">25+</span>
        <span class="ds-lbl">Years Experience</span>
      </div>
      <div class="ds-div"></div>
      <div class="ds-item">
        <span class="ds-val">99.99%</span>
        <span class="ds-lbl">Uptime Track Record</span>
      </div>
      <div class="ds-div"></div>
      <div class="ds-item">
        <span class="ds-val">60K+</span>
        <span class="ds-lbl">Users Migrated</span>
      </div>
      <div class="ds-div"></div>
      <div class="ds-item">
        <span class="ds-val">FDA</span>
        <span class="ds-lbl">21 CFR Part 11 Expert</span>
      </div>
    </div>

    <!-- What's inside -->
    <div class="door-vault">
      <div class="vault-label">Inside the Portfolio</div>
      <div class="vault-items">
        <div class="vault-item"><span class="vi-icon">📋</span> Full Career History</div>
        <div class="vault-item"><span class="vi-icon">🚀</span> 8 Flagship Projects</div>
        <div class="vault-item"><span class="vi-icon">🏆</span> Key Achievements & Metrics</div>
        <div class="vault-item"><span class="vi-icon">📄</span> 3 Tailored Resumes (PDF/Web)</div>
        <div class="vault-item"><span class="vi-icon">🎓</span> Certifications & Credentials</div>
        <div class="vault-item"><span class="vi-icon">🔒</span> Access-Controlled & Private</div>
      </div>
    </div>

    <!-- Actions -->
    <div class="door-actions">
      <a href="/request-access" class="btn-door-primary">
        🔑 Request Access
      </a>
      <a href="https://www.linkedin.com/in/brian-kuzdas-a176b945/" target="_blank" rel="noopener" class="btn-door-secondary">
        LinkedIn Profile ↗
      </a>
    </div>

    <p class="door-note">
      Already have access?
      <a href="/experience" class="door-enter-link">Enter the portfolio →</a>
    </p>

  </main>

  <!-- Footer -->
  <footer class="door-footer">
    <span>📍 Madison, WI</span>
    <span class="door-footer-sep">·</span>
    <a href="mailto:brian.kuzdas@gmail.com">brian.kuzdas@gmail.com</a>
    <span class="door-footer-sep">·</span>
    <span>(608) 576-0655</span>
    <span class="door-footer-sep">·</span>
    <a href="https://www.linkedin.com/in/brian-kuzdas-a176b945/" target="_blank" rel="noopener">LinkedIn</a>
  </footer>

</div>

</DoorLayout>

<style>
/* ── DOOR SHELL ── */
.door {
  min-height: 100dvh;
  display: flex; flex-direction: column;
  position: relative; overflow: hidden;
}

.door-grid {
  position: fixed; inset: 0; z-index: 0;
  background-image:
    linear-gradient(rgba(200,150,30,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,150,30,.05) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: radial-gradient(ellipse 90% 90% at 50% 40%, black 20%, transparent 100%);
  pointer-events: none;
}

/* ── HEADER ── */
.door-header {
  position: relative; z-index: 10;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.5rem 2.5rem;
  border-bottom: 1px solid rgba(255,255,255,.07);
}
.door-logo { display: flex; align-items: center; gap: 0.75rem; }
.logo-mark {
  width: 38px; height: 38px; border-radius: 8px;
  background: linear-gradient(135deg, #c8961e, #e8b840);
  color: #071a3e; font-weight: 900; font-size: 0.8rem;
  display: flex; align-items: center; justify-content: center;
  letter-spacing: 0.05em; flex-shrink: 0;
}
.logo-name { font-weight: 700; font-size: 1rem; color: rgba(255,255,255,.9); }
.door-ext { font-size: 0.8rem; color: rgba(255,255,255,.35); transition: color 200ms; }
.door-ext:hover { color: rgba(255,255,255,.7); }

/* ── MAIN ── */
.door-main {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  padding: 4rem 2rem;
  position: relative; z-index: 10;
  max-width: 780px; margin-inline: auto; width: 100%;
}

.door-eyebrow {
  display: flex; align-items: center; gap: 0.6rem;
  font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,.4);
  margin-bottom: 2rem;
}
.door-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #c8961e;
  box-shadow: 0 0 8px rgba(200,150,30,.6);
  animation: glow 2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes glow {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.door-headline {
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 900; line-height: 1.1;
  letter-spacing: -0.04em;
  margin-bottom: 1.5rem;
  color: var(--white);
}
.door-headline-sub {
  display: block;
  font-size: 0.55em;
  font-weight: 600;
  color: rgba(255,255,255,.45);
  letter-spacing: 0.01em;
  margin-top: 0.3em;
}

.door-desc {
  font-size: 1.05rem;
  color: rgba(255,255,255,.6);
  max-width: 52ch; line-height: 1.8;
  margin-bottom: 2.5rem;
}

/* ── STATS ── */
.door-stats {
  display: flex; align-items: center; gap: 0;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 14px; overflow: hidden;
  margin-bottom: 2.5rem; width: 100%;
}
.ds-item {
  flex: 1; padding: 1.25rem 1rem; text-align: center;
}
.ds-val {
  display: block;
  font-size: 1.5rem; font-weight: 900; color: #c8961e;
  letter-spacing: -0.03em; line-height: 1; margin-bottom: 4px;
}
.ds-lbl {
  font-size: 0.65rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.1em; color: rgba(255,255,255,.35);
}
.ds-div {
  width: 1px; background: rgba(255,255,255,.1);
  align-self: stretch;
}

/* ── VAULT PREVIEW ── */
.door-vault {
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 14px; padding: 1.5rem 2rem;
  margin-bottom: 2.5rem; width: 100%;
  text-align: left;
}
.vault-label {
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.15em; color: #c8961e; margin-bottom: 1rem;
}
.vault-items {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.6rem;
}
.vault-item {
  display: flex; align-items: center; gap: 0.6rem;
  font-size: 0.875rem; color: rgba(255,255,255,.6);
  padding: 0.5rem 0.75rem;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 8px;
}
.vi-icon { font-size: 1rem; flex-shrink: 0; }

/* ── ACTIONS ── */
.door-actions {
  display: flex; flex-wrap: wrap; gap: 1rem;
  justify-content: center; margin-bottom: 1.5rem;
}
.btn-door-primary {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 2rem;
  background: linear-gradient(135deg, #c8961e, #e8b840);
  color: #071a3e; font-weight: 800; font-size: 0.95rem;
  border-radius: 10px; border: none;
  box-shadow: 0 4px 20px rgba(200,150,30,.3);
  transition: all 200ms; cursor: pointer;
  text-decoration: none;
}
.btn-door-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 28px rgba(200,150,30,.5);
}
.btn-door-secondary {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.85rem 2rem;
  background: transparent; color: rgba(255,255,255,.75);
  font-weight: 600; font-size: 0.95rem;
  border-radius: 10px; border: 1px solid rgba(255,255,255,.2);
  transition: all 200ms; text-decoration: none;
}
.btn-door-secondary:hover {
  background: rgba(255,255,255,.07);
  border-color: rgba(255,255,255,.4);
  color: var(--white);
}

.door-note {
  font-size: 0.85rem; color: rgba(255,255,255,.3);
}
.door-enter-link {
  color: rgba(255,255,255,.5);
  text-decoration: underline; text-underline-offset: 3px;
  transition: color 200ms;
}
.door-enter-link:hover { color: rgba(255,255,255,.85); }

/* ── FOOTER ── */
.door-footer {
  position: relative; z-index: 10;
  display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
  gap: 0.4rem 0.75rem;
  padding: 1.25rem 2rem;
  border-top: 1px solid rgba(255,255,255,.07);
  font-size: 0.8rem; color: rgba(255,255,255,.25);
}
.door-footer a { color: rgba(255,255,255,.3); }
.door-footer a:hover { color: rgba(255,255,255,.6); }
.door-footer-sep { color: rgba(255,255,255,.15); }

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
  .door-header { padding: 1.25rem 1.5rem; }
  .door-main { padding: 3rem 1.5rem; }
  .door-stats { flex-direction: column; }
  .ds-div { width: 100%; height: 1px; }
  .vault-items { grid-template-columns: 1fr; }
}
</style>
