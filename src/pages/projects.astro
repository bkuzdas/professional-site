---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    num: '01',
    emoji: '🏭',
    title: 'Greenfield cGMP IT Infrastructure',
    company: 'FUJIFILM Cellular Dynamics',
    year: '2022–2025',
    category: 'Infrastructure Build',
    status: 'Delivered',
    summary: 'Built and validated the entire IT environment from zero for an FDA-regulated iPSC biopharmaceutical manufacturer. Architected all server, storage, network, and cloud systems supporting cGMP manufacturing operations.',
    outcomes: [
      '99.99% uptime across all manufacturing-critical systems',
      'Zero FDA audit findings across all inspections',
      'Full FDA 21 CFR Part 11 & cGMP CSV compliance achieved',
      'OPEX/CAPEX budget delivered without overruns',
    ],
    tags: ['cGMP', 'FDA 21 CFR Part 11', 'Azure', 'AWS', 'Dell EMC', 'Greenfield'],
    color: '#0d3b6e',
    image: '/images/server-room-fcdi.jpg',
    imageAlt: 'Server room built for FUJIFILM Cellular Dynamics cGMP manufacturing facility',
  },
  {
    num: '02',
    emoji: '☁️',
    title: '60,000-User Google Workspace → Microsoft 365 Migration',
    company: 'FUJIFILM Holdings America',
    year: '2020–2022',
    category: 'Cloud Migration',
    status: 'Delivered',
    summary: 'Led the enterprise-wide platform migration for a globally distributed organization of 60,000+ users. Coordinated data migration, identity provisioning, application dependencies, and user training across multiple business units.',
    outcomes: [
      '60,000+ users migrated with zero data loss',
      'Project delivered on schedule across global teams',
      'Minimal end-user disruption during cutover',
      'Full rollback procedures tested and documented',
    ],
    tags: ['Microsoft 365', 'Google Workspace', 'Enterprise Scale', 'Identity Management', 'Change Management'],
    color: '#0d3b6e',
  },
  {
    num: '03',
    emoji: '🔬',
    title: 'HL7 FHIR R4 Laboratory Data Ingestor',
    company: 'FUJIFILM Cellular Dynamics',
    year: '2023',
    category: 'Systems Integration',
    status: 'Delivered',
    summary: 'Architected a laboratory data integration platform connecting scientific instrumentation to enterprise systems. Enabled real-time data capture, retrieval, and reporting for cGMP manufacturing operations — with full FDA audit trail compliance.',
    outcomes: [
      '30% improvement in laboratory data retrieval speed',
      'Real-time instrument data available to scientific teams',
      'Full FDA 21 CFR Part 11 audit trail compliance',
      'Replaced error-prone manual file-based workflows',
    ],
    tags: ['HL7 FHIR R4', 'Lab Integration', 'REST APIs', 'FDA Compliance', 'Data Architecture'],
    color: '#1a5c38',
  },
  {
    num: '04',
    emoji: '🔐',
    title: 'WireGuard Zero Trust Remote Access',
    company: 'FUJIFILM Cellular Dynamics',
    year: '2023',
    category: 'Security Architecture',
    status: 'Delivered',
    summary: 'Designed and deployed a Zero Trust network access solution to replace legacy VPN infrastructure. Implemented identity-aware, least-privilege connectivity eliminating broad network access — deployed without impacting cGMP manufacturing availability.',
    outcomes: [
      'Eliminated broad network access model (legacy VPN)',
      'Identity-aware, least-privilege connectivity enforced',
      'Significant reduction in network attack surface',
      'Zero production downtime during cutover',
    ],
    tags: ['WireGuard', 'Zero Trust', 'Network Security', 'Remote Access', 'Identity'],
    color: '#1a5c38',
  },
  {
    num: '05',
    emoji: '🤖',
    title: 'On-Premise AI Infrastructure Strategy',
    company: 'Bankers Bank',
    year: '2025–Present',
    category: 'AI Infrastructure',
    status: 'In Progress',
    summary: 'Architecting an on-premise AI strategy for a Federal Reserve member bank, enabling AI-assisted internal operations while maintaining strict regulatory compliance and data sovereignty requirements of the financial sector.',
    outcomes: [
      'On-premise AI deployment keeps sensitive data sovereign',
      'Regulatory alignment with federal banking standards',
      'Scalable GPU/compute architecture design',
      'AI governance and usage policy framework',
    ],
    tags: ['AI Infrastructure', 'On-Premise', 'Financial Compliance', 'GPU Compute', 'Data Sovereignty'],
    color: '#c8961e',
  },
  {
    num: '06',
    emoji: '🖥️',
    title: 'Unified Endpoint Management (UEM) Transition',
    company: 'Bankers Bank',
    year: '2026–Present',
    category: 'Endpoint Management',
    status: 'In Progress',
    summary: 'Leading full transition from legacy endpoint management tools to a modern Unified Endpoint Management (UEM) platform across the organization. Includes vendor evaluation, phased rollout planning, and policy enforcement hardening.',
    outcomes: [
      'Vendor evaluation & selection completed',
      'Phased rollout plan across all device classes',
      'Unified policy enforcement for all endpoints',
      'Improved visibility into fleet health and compliance',
    ],
    tags: ['UEM', 'Endpoint Management', 'MDM', 'Policy Enforcement', 'Device Management'],
    color: '#c8961e',
  },
  {
    num: '07',
    emoji: '⚙️',
    title: 'Windows Firewall Security Profiler',
    company: 'FUJIFILM Cellular Dynamics',
    year: '2023',
    category: 'Security Automation',
    status: 'Delivered',
    summary: 'Developed a PowerShell-based automated tool to audit Windows Firewall policy compliance across the managed endpoint fleet. Generates remediation reports and integrates with monitoring infrastructure to flag policy drift in real time.',
    outcomes: [
      'Automated detection of firewall policy drift',
      'Remediation reports generated for IT and security teams',
      'Reduced manual audit effort significantly',
      'Consistent policy enforcement across all endpoints',
    ],
    tags: ['PowerShell', 'Windows Firewall', 'Security Automation', 'Compliance', 'Endpoint Hardening'],
    color: '#0d3b6e',
  },
  {
    num: '08',
    emoji: '🚀',
    title: 'TBC Consulting LLC — MSP Build & Scale',
    company: 'TBC Consulting (Founder)',
    year: '2012–2016',
    category: 'Entrepreneurship',
    status: 'Delivered',
    summary: 'Founded a Managed Service Provider from zero, built a client base of 25+ organizations, and operated successfully for 4 years across multiple industries in Greater Madison, WI. Full P&L responsibility with vCIO advisory as a core service offering.',
    outcomes: [
      'Grew from 0 to 25+ active client organizations',
      'Profitable within first year of operation',
      'Delivered managed IT services across healthcare, legal, and professional services',
      'Built trusted vCIO relationships with business owners',
    ],
    tags: ['Entrepreneurship', 'MSP', 'vCIO', 'Business Development', 'Managed Services'],
    color: '#5a1a00',
  },
