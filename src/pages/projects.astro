---
<Layout title="Projects — Brian Kuzdas" page="projects">

<section class="page-hero">
  <div class="container">
    <p class="section-label">Selected Work</p>
    <h1 class="page-hero-title">Projects</h1>
    <p class="page-hero-sub">
      Flagship infrastructure builds, platform migrations, security initiatives,
      and automation projects across 25+ years of enterprise IT leadership.
    </p>
  </div>
</section>

<!-- ══ FILTER STRIP ══════════════════════════════════════ -->
<div class="filter-bar">
  <div class="container filter-inner">
    <button class="filter-btn active" data-filter="all">All Projects</button>
    <button class="filter-btn" data-filter="Infrastructure Build">Infrastructure</button>
    <button class="filter-btn" data-filter="Cloud Migration">Cloud</button>
    <button class="filter-btn" data-filter="Security Architecture">Security</button>
    <button class="filter-btn" data-filter="AI Infrastructure">AI</button>
    <button class="filter-btn" data-filter="Entrepreneurship">Entrepreneurship</button>
  </div>
</div>

<!-- ══ PROJECTS GRID ══════════════════════════════════════ -->
<section class="section">
  <div class="container">
    <div class="projects-grid" id="projectsGrid">
      {projects.map(p => (
        <div class="project-card" data-category={p.category} style={`--pc: ${p.color};`}>
          <div class="pc-top-bar"></div>
          {p.image && (
            <div class="pc-img-wrap">
              <img src={p.image} alt={p.imageAlt} class="pc-img" loading="lazy" />
            </div>
          )}
          <div class="pc-body">
            <div class="pc-head">
              <span class="pc-num">{p.num}</span>
              <div class="pc-meta">
                <span class="pc-category">{p.category}</span>
                <span class={`pc-status ${p.status === 'In Progress' ? 'status--active' : 'status--done'}`}>
                  {p.status === 'In Progress' ? '● In Progress' : '✔ Delivered'}
                </span>
              </div>
            </div>
            <div class="pc-emoji">{p.emoji}</div>
            <h2 class="pc-title">{p.title}</h2>
            <div class="pc-company">{p.company} · {p.year}</div>
            <p class="pc-summary">{p.summary}</p>
            <div class="pc-outcomes">
              <div class="pc-outcomes-label">Key Outcomes</div>
              <ul>
                {p.outcomes.map(o => <li>{o}</li>)}
              </ul>
            </div>
            <div class="pc-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ CTA ═════════════════════════════════════════════ -->
<section class="cta-section">
  <div class="container cta-inner">
    <div>
      <h2 class="cta-title">Want to see the full story?</h2>
      <p class="cta-sub">View my complete career history or download a tailored resume.</p>
    </div>
    <div class="cta-actions">
      <a href="/achievements" class="btn btn-gold">Achievements</a>
      <a href="/resumes" class="btn btn-outline-white">Resumes</a>
      <a href="/experience" class="btn btn-outline-white">Experience</a>
    </div>
  </div>
</section>

</Layout>

<style>
/* ── FILTER BAR ── */
.filter-bar {
  background: var(--white);
  border-bottom: 1px solid var(--border-soft);
  position: sticky; top: var(--nav-height); z-index: 50;
  box-shadow: var(--shadow-sm);
}
.filter-inner {
  display: flex; gap: 8px; padding-block: var(--sp-md);
  overflow-x: auto; scrollbar-width: none;
}
.filter-inner::-webkit-scrollbar { display: none; }
.filter-btn {
  font-size: 0.8rem; font-weight: 600;
  padding: 6px 16px; border-radius: 20px;
  border: 1px solid var(--border);
  background: transparent; color: var(--sub);
  cursor: pointer; white-space: nowrap;
  transition: all var(--transition);
}
.filter-btn:hover { border-color: var(--navy); color: var(--navy); }
.filter-btn.active {
  background: var(--navy); color: var(--white); border-color: var(--navy);
}

/* ── PROJECTS GRID ── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
  gap: var(--sp-xl);
}
.project-card {
  background: var(--white);
  border: 1px solid var(--border-soft);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition), transform var(--transition), opacity var(--transition);
}
.project-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.project-card.hidden { display: none; }
.pc-top-bar { height: 4px; background: var(--pc, var(--navy)); }
.pc-img-wrap { overflow: hidden; max-height: 220px; }
.pc-img { width: 100%; height: 220px; object-fit: cover; object-position: center; display: block; transition: transform 0.4s ease; }
.project-card:hover .pc-img { transform: scale(1.03); }
.pc-body { padding: var(--sp-xl); }
.pc-head {
  display: flex; align-items: center;
  justify-content: space-between; margin-bottom: var(--sp-md);
}
.pc-num {
  font-size: 1.75rem; font-weight: 900;
  color: var(--border); line-height: 1; letter-spacing: -0.05em;
}
.pc-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
.pc-category {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--pc, var(--navy));
}
.pc-status {
  font-size: 0.7rem; font-weight: 600; padding: 2px 9px;
  border-radius: 20px;
}
.status--done { background: #d1fae5; color: #065f46; }
.status--active { background: #fef3c7; color: #92400e; }
.pc-emoji { font-size: 2.25rem; margin-bottom: var(--sp-sm); }
.pc-title {
  font-size: 1.05rem; font-weight: 800; color: var(--navy);
  line-height: 1.3; margin-bottom: 6px;
}
.pc-company { font-size: 0.8rem; color: var(--gold); font-weight: 600; margin-bottom: var(--sp-md); }
.pc-summary {
  font-size: 0.875rem; color: var(--sub); line-height: 1.7;
  margin-bottom: var(--sp-lg);
}
.pc-outcomes { margin-bottom: var(--sp-lg); }
.pc-outcomes-label {
  font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: var(--muted); margin-bottom: var(--sp-sm);
}
.pc-outcomes ul { padding-left: 1.1rem; }
.pc-outcomes li {
  font-size: 0.82rem; color: var(--muted); line-height: 1.6;
  margin-bottom: 0.3rem;
}
.pc-tags { display: flex; flex-wrap: wrap; gap: 5px; }

/* ── CTA ── */
.cta-section { background: linear-gradient(135deg, var(--navy-dark), var(--navy)); padding-block: var(--sp-4xl); }
.cta-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-2xl); }
.cta-title { font-size: 1.8rem; font-weight: 800; color: var(--white); margin-bottom: var(--sp-sm); }
.cta-sub { font-size: 1rem; color: rgba(255,255,255,.7); max-width: 50ch; }
.cta-actions { display: flex; flex-wrap: wrap; gap: var(--sp-md); }

@media (max-width: 760px) {
  .projects-grid { grid-template-columns: 1fr; }
  .cta-inner { flex-direction: column; text-align: center; }
  .cta-actions { justify-content: center; }
}
</style>

<script>
  const btns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
