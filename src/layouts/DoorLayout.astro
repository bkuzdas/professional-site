---
export interface Props {
  title?: string;
  description?: string;
}

import '../styles/global.css';

const {
  title = 'Brian Kuzdas — Professional Portfolio',
  description = 'Senior IT Infrastructure leader with 25+ years in enterprise networking, cGMP compliance, and technology strategy.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0d2b5e" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body class="door-body">
  <slot />
</body>
</html>

<style>
.door-body {
  margin: 0; padding: 0;
  font-family: var(--font);
  background: var(--navy-dark);
  color: var(--white);
  min-height: 100dvh;
  -webkit-font-smoothing: antialiased;
}
</style>
